# Core API Configuration
PROJECT_NAME="Artist Collaboration Engine"
API_V1_STR="/api/v1"

# PostgreSQL Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=artist_collab_db
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5432/artist_collab_db

# Redis Cache & Rate Limiter Configuration
REDIS_URL=redis://localhost:6379

# MinIO Storage Engine Configuration
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=your_minio_secret_here
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_BUCKET_NAME=artist-portfolio-assets